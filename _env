# Copia este archivo como ".env" y completa tus datos.
# NUNCA subas el archivo .env real a git ni lo compartas.

# --- Credenciales de Binance FUTURES DEMO TRADING (antes llamada "Testnet") ---
# Consíguelas en: https://demo.binance.com (sección API Key de Demo Trading)
BINANCE_API_KEY='AQUI_BINANCE_API_KEY'
BINANCE_API_SECRET='AQUI_BINANCE_API_SECRET'

# TESTNET debe quedar en true mientras pruebas. NO lo cambies a false
# a menos que entiendas el riesgo y quieras operar con dinero real.
TESTNET=true

# --- Mercado ---
SYMBOL=BTCUSDT
INTERVAL=1m
LEVERAGE=7
MARGIN_TYPE=ISOLATED

# --- Capital ---
CAPITAL_USDT=200
MAX_MARGIN_PCT_PER_TRADE=25.0

# --- Riesgo por operación (monto FIJO en USDT que se arriesga si toca el SL) ---
RISK_USDT_PER_TRADE=4.0
# Relación ganancia/riesgo objetivo (TP = distancia_SL * este número)
REWARD_RISK_RATIO=4.0

# --- Bandas de Bollinger (definen la distancia del SL) ---
BB_PERIOD=20
BB_STD=2.0
MIN_SL_PCT=0.10
MAX_SL_PCT=0.60

# --- Estocástico (entradas y salidas) ---
STOCH_K_PERIOD=14
STOCH_D_PERIOD=3
STOCH_SMOOTH_K=3
STOCH_OVERSOLD=20
STOCH_OVERBOUGHT=80

# --- Alligator (Bill Williams, define la tendencia) ---
ALLIGATOR_JAW_PERIOD=13
ALLIGATOR_JAW_SHIFT=8
ALLIGATOR_TEETH_PERIOD=8
ALLIGATOR_TEETH_SHIFT=5
ALLIGATOR_LIPS_PERIOD=5
ALLIGATOR_LIPS_SHIFT=3
ALLIGATOR_MIN_SEPARATION_PCT=0.05

# --- Límites de seguridad ---
MAX_TRADES_PER_DAY=50
MAX_CONSECUTIVE_LOSSES=2
DAILY_MAX_LOSS_PCT=10
LOOP_SLEEP_SECONDS=15

LOG_FILE=trades_log.csv
